  lotteryDrawnAt                DateTime?                      @db.Timestamptz(3)
  lotteryAnnouncement           String?
  editableUntil                 DateTime?                      @db.Timestamptz(3)
  appendedContent               String?
  lastAppendedAt                DateTime?                      @db.Timestamptz(3)
  lastCommentedAt               DateTime?                      @db.Timestamptz(3)
  activityAt                    DateTime                       @default(now()) @db.Timestamptz(3)
  publishedAt                   DateTime?                      @db.Timestamptz(3)
  createdAt                     DateTime                       @default(now()) @db.Timestamptz(3)
  updatedAt                     DateTime                       @updatedAt @db.Timestamptz(3)
