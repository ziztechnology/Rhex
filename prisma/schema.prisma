  author                        User                           @relation(fields: [authorId], references: [id])
  acceptedComment               Comment?                       @relation("AcceptedBountyComment", fields: [acceptedCommentId], references: [id])
  comments                      Comment[]
  favorites                     Favorite[]
  favoriteCollectionItems       FavoriteCollectionItem[]
  favoriteCollectionSubmissions FavoriteCollectionSubmission[]
  likes                         Like[]
  tags                          PostTag[]
  pollOptions                   PollOption[]
  pollVotes                     PollVote[]
  lotteryPrizes                 LotteryPrize[]
  lotteryConditions             LotteryCondition[]
  lotteryParticipants           LotteryParticipant[]
  lotteryWinners                LotteryWinner[]
  appendices                    PostAppendix[]
  tips                          PostTip[]
  giftEvents                    PostGiftEvent[]
  giftStats                     PostGiftStats[]
  auction                       PostAuction?
  redPacket                     PostRedPacket?
  redPacketClaims               PostRedPacketClaim[]
  blockPurchases                PostBlockPurchase[]
  attachments                   PostAttachment[]
  attachmentPurchases           PostAttachmentPurchase[]
  commentEffectFeedbacks        CommentEffectFeedback[]
  followers                     PostFollow[]
  aiReplyTasks                  AiReplyTask[]
  aiModerationSuggestions       AiModerationSuggestion[]
  autoCategorizeTasks           AutoCategorizeTask[]

