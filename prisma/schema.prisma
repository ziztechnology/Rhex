model Comment {
  id                     String                 @id @default(cuid())
  postId                 String
  userId                 Int
  parentId               String?
  replyToUserId          Int?
  replyToCommentId       String?
  privateRecipientUserId Int?
  useAnonymousIdentity   Boolean                @default(false)
  content                String
  status                 CommentStatus          @default(NORMAL)
  reviewNote             String?
  reviewedById           Int?
  reviewedAt             DateTime?              @db.Timestamptz(3)
  likeCount              Int                    @default(0)
  tipCount               Int                    @default(0)
  tipTotalPoints         Int                    @default(0)
  isAcceptedAnswer       Boolean                @default(false)
  isPinnedByAuthor       Boolean                @default(false)
  isGodComment           Boolean                @default(false)
  godCommentSource       GodCommentSource?
  godCommentedById       Int?
  godCommentedAt         DateTime?              @db.Timestamptz(3)
  acceptedAt             DateTime?              @db.Timestamptz(3)
  bountyAcceptedForPost  Post?                  @relation("AcceptedBountyComment")
  createdAt              DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime               @updatedAt @db.Timestamptz(3)
  post                   Post                   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user                   User                   @relation("commentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  parent                 Comment?               @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies                Comment[]              @relation("CommentReplies")
  replyToUser            User?                  @relation("replyToUser", fields: [replyToUserId], references: [id])
  replyToComment         Comment?               @relation("CommentReplyTargets", fields: [replyToCommentId], references: [id], onDelete: SetNull)
  privateRecipient       User?                  @relation("privateCommentRecipient", fields: [privateRecipientUserId], references: [id], onDelete: SetNull)
  quotedReplies          Comment[]              @relation("CommentReplyTargets")
  reviewer               User?                  @relation("commentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  godCommentedBy         User?                  @relation("commentGodCommentMarker", fields: [godCommentedById], references: [id], onDelete: SetNull)
  likes                  Like[]
  tips                   PostTip[]
  giftEvents             PostGiftEvent[]
  pollVotes              PollVote[]
  lotteryParticipants    LotteryParticipant[]
  redPacketClaims        PostRedPacketClaim[]
  effectFeedback         CommentEffectFeedback?
  aiReplyTasksAsSource   AiReplyTask[]          @relation("AiReplyTaskSourceComment")
  aiReplyTaskGenerated   AiReplyTask?           @relation("AiReplyTaskGeneratedComment")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([replyToCommentId])
  @@index([privateRecipientUserId])
  @@index([postId, status, createdAt])
  @@index([postId, status, parentId, createdAt])
  @@index([postId, status, parentId, isGodComment, isPinnedByAuthor, createdAt, id], map: "comment_thread_order_idx")
  @@index([postId, status, isGodComment, isPinnedByAuthor, createdAt, id], map: "comment_flat_order_idx")
  @@index([reviewedById, reviewedAt])
  @@index([godCommentedById, godCommentedAt])
}

