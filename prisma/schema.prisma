model User {
  id                               Int                            @id @default(autoincrement())
  username                         String                         @unique
  email                            String?                        @unique
  phone                            String?                        @unique
  emailVerifiedAt                  DateTime?                      @db.Timestamptz(3)
  phoneVerifiedAt                  DateTime?                      @db.Timestamptz(3)
  passwordHash                     String
  nickname                         String?                        @unique
  avatarPath                       String?
  bio                              String?
  signature                        String?
  gender                           String?
  role                             UserRole                       @default(USER)
  status                           UserStatus                     @default(ACTIVE)
  statusExpiresAt                  DateTime?                      @db.Timestamptz(3)
  statusReason                     String?
  points                           Int                            @default(0)
  level                            Int                            @default(1)
  vipLevel                         Int                            @default(0)
  vipExpiresAt                     DateTime?                      @db.Timestamptz(3)
  postCount                        Int                            @default(0)
  commentCount                     Int                            @default(0)
  likeReceivedCount                Int                            @default(0)
  godCommentCount                  Int                            @default(0)
  inviteCount                      Int                            @default(0)
  acceptedAnswerCount              Int                            @default(0)
  inviterId                        Int?
  lastPostAt                       DateTime?                      @db.Timestamptz(3)
  lastCommentAt                    DateTime?                      @db.Timestamptz(3)
  lastLoginAt                      DateTime?                      @db.Timestamptz(3)
  lastLoginIp                      String?
  sessionInvalidBefore             DateTime?                      @db.Timestamptz(3)
  createdAt                        DateTime                       @default(now()) @db.Timestamptz(3)
  updatedAt                        DateTime                       @updatedAt @db.Timestamptz(3)
  inviter                          User?                          @relation("UserInvites", fields: [inviterId], references: [id], onDelete: SetNull)
  invitedUsers                     User[]                         @relation("UserInvites")
  posts                            Post[]
  comments                         Comment[]                      @relation("commentAuthor")
  repliesReceived                  Comment[]                      @relation("replyToUser")
  privateCommentsReceived          Comment[]                      @relation("privateCommentRecipient")
  lotteryParticipations            LotteryParticipant[]
  lotteryWins                      LotteryWinner[]
  notifications                    Notification[]                 @relation("notificationUser")
  sentNotifications                Notification[]                 @relation("notificationSender")
  boardFollows                     BoardFollow[]
  followingUsers                   UserFollow[]                   @relation("UserFollowSource")
  followedByUsers                  UserFollow[]                   @relation("UserFollowTarget")
  blocksInitiated                  UserBlock[]                    @relation("UserBlockSource")
  blocksReceived                   UserBlock[]                    @relation("UserBlockTarget")
  tagFollows                       TagFollow[]
  postFollows                      PostFollow[]
  favorites                        Favorite[]
  ownedFavoriteCollections         FavoriteCollection[]           @relation("FavoriteCollectionOwner")
  favoriteCollectionItems          FavoriteCollectionItem[]       @relation("FavoriteCollectionItemAdder")
  submittedFavoriteCollectionPosts FavoriteCollectionSubmission[] @relation("FavoriteCollectionSubmissionUser")
  reviewedFavoriteCollectionPosts  FavoriteCollectionSubmission[] @relation("FavoriteCollectionSubmissionReviewer")
  likes                            Like[]
  reports                          Report[]                       @relation("reporter")
  handledReports                   Report[]                       @relation("handler")
  pointLogs                        PointLog[]
  postBlockPurchases               PostBlockPurchase[]            @relation("PostBlockPurchaseBuyer")
  postBlockSales                   PostBlockPurchase[]            @relation("PostBlockPurchaseSeller")
  postAttachmentPurchases          PostAttachmentPurchase[]       @relation("PostAttachmentPurchaseBuyer")
  postAttachmentSales              PostAttachmentPurchase[]       @relation("PostAttachmentPurchaseSeller")
  vipOrders                        VipOrder[]
  postTipsSent                     PostTip[]                      @relation("PostTipSender")
  postTipsReceived                 PostTip[]                      @relation("PostTipReceiver")
  postGiftEventsSent               PostGiftEvent[]                @relation("PostGiftSender")
  postGiftEventsReceived           PostGiftEvent[]                @relation("PostGiftReceiver")
  postGiftStatsReceived            PostGiftStats[]                @relation("PostGiftStatsReceiver")
  postAuctionsSelling              PostAuction[]                  @relation("PostAuctionSeller")
  postAuctionsWon                  PostAuction[]                  @relation("PostAuctionWinner")
  postAuctionEntries               PostAuctionEntry[]
  postAuctionBidRecords            PostAuctionBidRecord[]
  redPacketsSent                   PostRedPacket[]
  redPacketClaims                  PostRedPacketClaim[]           @relation("PostRedPacketClaimUser")
  commentEffectFeedbacks           CommentEffectFeedback[]
  checkInLogs                      UserCheckInLog[]
  pollVotes                        PollVote[]
  uploads                          Upload[]
  authAccounts                     AuthAccount[]
  authPasskeys                     AuthPasskey[]
  oauthClients                     OAuthClient[]                 @relation("OAuthClientOwner")
  reviewedOAuthClients             OAuthClient[]                 @relation("OAuthClientReviewer")
  paymentApplications              PaymentApplication[]          @relation("PaymentApplicationOwner")
  reviewedPaymentApplications      PaymentApplication[]          @relation("PaymentApplicationReviewer")
  paidPaymentTransactions           PaymentTransaction[]          @relation("PaymentTransactionPayer")
  oauthAuthorizationCodes          OAuthAuthorizationCode[]
  oauthAccessTokens                OAuthAccessToken[]
  oauthRefreshTokens               OAuthRefreshToken[]
  oauthConsents                    OAuthConsent[]
  userBadges                       UserBadge[]
  adminLogs                        AdminLog[]
  announcements                    Announcement[]                 @relation("announcementCreator")
  customPages                      CustomPage[]                   @relation("customPageCreator")
  attachmentReferenceScanJobs      UploadReferenceScanJob[]       @relation("UploadReferenceScanJobAdmin")
  loginLogs                        UserLoginLog[]
  messageParticipants              ConversationParticipant[]
  sentDirectMessages               DirectMessage[]
  levelProgress                    UserLevelProgress?
  generatedInviteCodes             InviteCode[]                   @relation("InviteCodeCreator")
  usedInviteCodes                  InviteCode[]                   @relation("InviteCodeConsumer")
  generatedRedeemCodes             RedeemCode[]                   @relation("RedeemCodeCreator")
  redeemedCodes                    RedeemCode[]                   @relation("RedeemCodeConsumer")
  verificationApplications         UserVerification[]             @relation("userVerificationApplicant")
  reviewedVerifications            UserVerification[]             @relation("userVerificationReviewer")
  reviewedComments                 Comment[]                      @relation("commentReviewer")
  godCommentedComments             Comment[]                      @relation("commentGodCommentMarker")
  rssReviewedEntries               RssEntry[]                     @relation("rssEntryReviewer")
  rssEntryLikes                    RssEntryLike[]
  rssEntryTips                     RssEntryTip[]                  @relation("RssEntryTipSender")
  rssSourceApplications            RssSourceApplication[]         @relation("rssSourceApplicationApplicant")
  rssSourceApplicationsReviewed    RssSourceApplication[]         @relation("rssSourceApplicationReviewer")
  yinYangChallengesCreated         YinYangChallenge[]             @relation("YinYangChallengeCreator")
  yinYangChallengesJoined          YinYangChallenge[]             @relation("YinYangChallengeChallenger")
  yinYangChallengeAttempts         YinYangChallengeAttempt[]
  yinYangChallengeDailyStats       YinYangChallengeDailyStat[]
  moderatedZoneScopes              ModeratorZoneScope[]
  moderatedBoardScopes             ModeratorBoardScope[]
  adminPermissionGrants            AdminPermissionGrant[]
  boardApplications                BoardApplication[]             @relation("boardApplicationApplicant")
  reviewedBoardApplications        BoardApplication[]             @relation("boardApplicationReviewer")
  aiReplyTasksTriggered            AiReplyTask[]                  @relation("AiReplyTaskTriggerUser")
  aiReplyTasksAssigned             AiReplyTask[]                  @relation("AiReplyTaskAgentUser")
  autoCategorizeTasksRequested     AutoCategorizeTask[]           @relation("AutoCategorizeTaskRequesterUser")
  paymentOrders                    PaymentOrder[]
  aiModerationSuggestionsReviewed  AiModerationSuggestion[]
  createdTaskDefinitions           TaskDefinition[]               @relation("TaskDefinitionCreator")
  updatedTaskDefinitions           TaskDefinition[]               @relation("TaskDefinitionUpdater")
  taskProgresses                   UserTaskProgress[]
  taskEventLedgers                 UserTaskEventLedger[]

  @@index([role])
  @@index([status])
  @@index([status, statusExpiresAt])
  @@index([createdAt])
  @@index([inviterId])
}

model AuthAccount {
  id                String   @id
  userId            Int
  provider          String
  providerAccountId String
  providerUsername  String?
  providerEmail     String?
  metadataJson      String?
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model AuthPasskey {
  id                  String    @id
  userId              Int
  credentialId        String    @unique
  credentialPublicKey String
  counter             BigInt    @default(0)
  deviceType          String?
  backedUp            Boolean   @default(false)
  transports          String?
  name                String?
  lastUsedAt          DateTime? @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(3)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([lastUsedAt])
}

model OAuthClient {
  id               String                 @id @default(cuid())
  ownerId          Int
  clientId         String                 @unique
  clientSecretHash String?
  name             String
  description      String?
  homepageUrl      String?
  logoUrl          String?
  redirectUris     String[]
  scopes           String[]
  status           OAuthClientStatus      @default(PENDING)
  reviewNote       String?
  reviewedById     Int?
  reviewedAt       DateTime?              @db.Timestamptz(3)
  secretRotatedAt  DateTime?              @db.Timestamptz(3)
  createdAt        DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime               @updatedAt @db.Timestamptz(3)
  owner            User                   @relation("OAuthClientOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewer         User?                  @relation("OAuthClientReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]
  refreshTokens      OAuthRefreshToken[]
  consents           OAuthConsent[]

  @@index([ownerId, status, createdAt])
  @@index([status, createdAt])
  @@index([reviewedById, reviewedAt])
}

model OAuthAuthorizationCode {
  id                  String      @id @default(cuid())
  codeHash            String      @unique
  clientId            String
  userId              Int
  redirectUri         String
  scopes              String[]
  codeChallenge       String
  codeChallengeMethod String
  nonce               String?
  state               String?
  expiresAt           DateTime    @db.Timestamptz(3)
  consumedAt          DateTime?   @db.Timestamptz(3)
  createdAt           DateTime    @default(now()) @db.Timestamptz(3)
  client              OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([userId, createdAt])
  @@index([expiresAt])
}

model OAuthAccessToken {
  id              String      @id @default(cuid())
  tokenHash       String      @unique
  clientId        String
  userId          Int
  scopes          String[]
  expiresAt       DateTime    @db.Timestamptz(3)
  revokedAt       DateTime?   @db.Timestamptz(3)
  createdAt       DateTime    @default(now()) @db.Timestamptz(3)
  client          OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens   OAuthRefreshToken[]

  @@index([clientId, createdAt])
  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

model OAuthRefreshToken {
  id            String            @id @default(cuid())
  tokenHash     String            @unique
  accessTokenId String?
  clientId      String
  userId        Int
  scopes        String[]
  expiresAt     DateTime          @db.Timestamptz(3)
  revokedAt     DateTime?         @db.Timestamptz(3)
  createdAt     DateTime          @default(now()) @db.Timestamptz(3)
  rotatedAt     DateTime?         @db.Timestamptz(3)
  client        OAuthClient       @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken   OAuthAccessToken? @relation(fields: [accessTokenId], references: [id], onDelete: SetNull)

  @@index([accessTokenId])
  @@index([clientId, userId])
  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

model OAuthConsent {
  id        String      @id @default(cuid())
  clientId  String
  userId    Int
  scopes    String[]
  createdAt DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt DateTime    @updatedAt @db.Timestamptz(3)
  client    OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([userId, updatedAt])
}

model PaymentApplication {
  id              String                   @id @default(cuid())
  ownerId         Int
  paymentId       String                   @unique
  secretHash      String
  name            String
  description     String?
  homepageUrl     String?
  callbackUrl     String
  status          PaymentApplicationStatus @default(PENDING)
  reviewNote      String?
  reviewedById    Int?
  reviewedAt      DateTime?                @db.Timestamptz(3)
  secretRotatedAt DateTime?                @db.Timestamptz(3)
  createdAt       DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @db.Timestamptz(3)
  owner           User                     @relation("PaymentApplicationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewer        User?                    @relation("PaymentApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  transactions    PaymentTransaction[]

  @@index([ownerId, status, createdAt])
  @@index([status, createdAt])
  @@index([reviewedById, reviewedAt])
}

model PaymentTransaction {
  id             String                   @id @default(cuid())
  transactionId  String                   @unique
  applicationId  String
  payerId        Int?
  orderId        String
  amount         Int
  platformFee    Int                      @default(0)
  merchantPoints Int
  description    String
  status         PaymentTransactionStatus @default(PENDING)
  errorMessage   String?
  paidAt         DateTime?                @db.Timestamptz(3)
  expiresAt      DateTime                 @db.Timestamptz(3)
  createdAt      DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime                 @updatedAt @db.Timestamptz(3)
  application    PaymentApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  payer          User?                    @relation("PaymentTransactionPayer", fields: [payerId], references: [id], onDelete: SetNull)

  @@unique([applicationId, orderId])
  @@index([applicationId, status, createdAt])
  @@index([payerId, createdAt])
  @@index([status, expiresAt])
}

model UserLevelProgress {
  id                   String   @id @default(cuid())
  userId               Int      @unique
  checkInDays          Int      @default(0)
  currentCheckInStreak Int      @default(0)
  maxCheckInStreak     Int      @default(0)
  lastCheckInDate      String?
  receivedPostLikes    Int      @default(0)
  receivedCommentLikes Int      @default(0)
  receivedLikeCount    Int      @default(0)
  updatedAt            DateTime @updatedAt @db.Timestamptz(3)
  createdAt            DateTime @default(now()) @db.Timestamptz(3)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GobangMatch {
  id           String            @id
  creatorId    Int
  challengerId Int?
  status       GobangMatchStatus
  winnerId     Int?
  ticketCost   Int
  winReward    Int
  createdAt    DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime          @updatedAt @db.Timestamptz(3)

  @@index([creatorId])
  @@index([challengerId])
  @@index([status])
}

model GobangMove {
  id        String   @id
  matchId   String
  playerId  Int
  step      Int
  x         Int
  y         Int
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([matchId, step])
}

model SelfServeAdOrder {
  id              String                 @id
  appCode         String                 @default("self-serve-ads")
  userId          Int
  slotType        SelfServeAdSlotType
  slotIndex       Int
  title           String?
  linkUrl         String
  imageUrl        String?
  textColor       String?
  backgroundColor String?
  durationMonths  Int
  pricePoints     Int
  status          SelfServeAdOrderStatus
  reviewNote      String?
  startsAt        DateTime?              @db.Timestamptz(3)
  endsAt          DateTime?              @db.Timestamptz(3)
  createdAt       DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime               @updatedAt @db.Timestamptz(3)

  @@index([status, slotType, slotIndex])
  @@index([userId, createdAt])
  @@map("SelfServeAdOrder")
}

model YinYangChallenge {
  id            String                   @id
  creatorId     Int
  challengerId  Int?
  status        YinYangChallengeStatus
  question      String
  optionA       String
  optionB       String
  correctOption YinYangOption
  stakePoints   Int
  rewardPoints  Int
  taxRateBps    Int
  taxPoints     Int
  winnerId      Int?
  loserId       Int?
  expiresAt     DateTime?                @db.Timestamptz(3)
  settledAt     DateTime?                @db.Timestamptz(3)
  createdAt     DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime                 @updatedAt @db.Timestamptz(3)
  creator       User                     @relation("YinYangChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  challenger    User?                    @relation("YinYangChallengeChallenger", fields: [challengerId], references: [id], onDelete: SetNull)
  attempt       YinYangChallengeAttempt?

  @@index([creatorId, createdAt])
  @@index([challengerId, updatedAt])
  @@index([status, createdAt])
  @@index([winnerId, settledAt])
  @@index([loserId, settledAt])
}

model YinYangChallengeAttempt {
