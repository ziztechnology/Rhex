  id          String   @id @default(cuid())
  userId      Int
  reward      Int
  checkedInOn String
  isMakeUp    Boolean  @default(false)
  makeUpCost  Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkedInOn])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([checkedInOn])
}

model UserTaskProgress {
  id                    String                 @id @default(cuid())
  userId                Int
  taskId                String
  cycleKey              String
  categorySnapshot      TaskCategory
  cycleTypeSnapshot     TaskCycleType
  conditionTypeSnapshot TaskConditionType
  targetCountSnapshot   Int
  rewardTierSnapshot    TaskRewardTier
  rewardMinSnapshot     Int
  rewardMaxSnapshot     Int
  progressCount         Int                    @default(0)
  settledRewardPoints   Int?
  status                UserTaskProgressStatus @default(IN_PROGRESS)
  completedAt           DateTime?              @db.Timestamptz(3)
  settledAt             DateTime?              @db.Timestamptz(3)
  metadataJson          Json?
  createdAt             DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime               @updatedAt @db.Timestamptz(3)
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  task                  TaskDefinition         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId, cycleKey])
  @@index([userId, categorySnapshot, cycleKey])
  @@index([userId, status, updatedAt])
  @@index([taskId, cycleKey])
}

model UserTaskEventLedger {
  id        String         @id @default(cuid())
  userId    Int
  taskId    String
  cycleKey  String
  eventKey  String
  createdAt DateTime       @default(now()) @db.Timestamptz(3)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      TaskDefinition @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId, cycleKey, eventKey])
  @@index([userId, createdAt])
  @@index([taskId, cycleKey, createdAt])
}

model UserLoginLog {
  id        String   @id @default(cuid())
  userId    Int
  ip        String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ===== AI capabilities (plan_ai_reply_enhance Step 6) =====

model AiUsageDaily {
  id        String   @id @default(cuid())
  appKey    String
  day       DateTime @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([appKey, day])
  @@index([day])
}

model AiSummaryCache {
  id          String   @id @default(cuid())
  sourceKind  String
  sourceId    String
  contentHash String
  summary     String
  modelKey    String
  hitCount    Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  lastHitAt   DateTime @default(now()) @db.Timestamptz(3)

  @@unique([sourceKind, sourceId, contentHash, modelKey])
  @@index([sourceKind, sourceId])
  @@index([createdAt])
}

model AiModerationSuggestion {
  id                String             @id @default(cuid())
  postId            String
  suggestedBoardId  String?
  suggestedTagIds   String[]
  suggestedTagsJson Json?
  reasoning         String?
  modelKey          String
  status            AiModerationStatus @default(PENDING)
  reviewerId        Int?
  decidedAt         DateTime?          @db.Timestamptz(3)
  createdAt         DateTime           @default(now()) @db.Timestamptz(3)

  post           Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  suggestedBoard Board? @relation(fields: [suggestedBoardId], references: [id], onDelete: SetNull)
  reviewer       User?  @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([status, createdAt])
  @@index([reviewerId])
}
